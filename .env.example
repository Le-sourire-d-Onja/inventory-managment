# Secret JWT (≥ 32 caractères). Chaque caractère `$` doit être écrit `\$`
# dans le fichier, sinon Next.js le supprime (expansion de variables).
# Exemple avec guillemets si le secret contient # ou autres caractères spéciaux :
# AUTH_JWT_SECRET="monSecret#avec\$unDollarEt\$encore"
AUTH_JWT_SECRET=

# Hash bcrypt du mot de passe. Même règle : échapper chaque `$` avec `\$`
# APP_PASSWORD_HASH=\$2y\$10\$..................................................
APP_PASSWORD_HASH=

# Database URL of the PostgreSQL database
DATABASE_URL=
